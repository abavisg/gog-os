GOGOS_TIMEZONE=Europe/London
GOOGLE_CREDENTIALS_PATH=.core/config/secrets/google_credentials.json

# Accounts are registered via /account-add <alias> <email>
# and stored in .core/config/accounts.json — no env vars needed.
# These legacy vars are a fallback only (deprecated):
# GOGOS_DEFAULT_ACCOUNT=personal
# GOGOS_ACCOUNTS=personal,work
GMAIL_DEFAULT_QUERY=in:inbox newer_than:2d
GMAIL_MAX_RESULTS=100
CALENDAR_DEFAULT_ID=primary
NEWS_DEFAULT_FEEDS=ai,claude_code,finance
